# ============================================
# Net2App Blast — Environment Variables
# ============================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# ============================================
# DATABASE (required)
# ============================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://net2app_user:CHANGE_ME@127.0.0.1:5432/net2app_db

# ============================================
# AUTHENTICATION (required for production)
# ============================================
# JWT secret for signing tokens — CHANGE THIS in production!
JWT_SECRET=change-this-to-a-random-64-char-string

# ============================================
# NEXT.JS
# ============================================
# Node environment: development | production
NODE_ENV=production

# Next.js app port (default: 3000)
PORT=3000

# ============================================
# SMPP GATEWAY (Node.js ESMC Server)
# ============================================
# ESMC server bind address (default: 0.0.0.0)
SMPP_ESMC_HOST=0.0.0.0

# ESMC server listen port — clients connect here (default: 2775)
SMPP_ESMC_PORT=2775

# REST API bridge host (default: 127.0.0.1)
SMPP_API_HOST=127.0.0.1

# REST API bridge port (default: 9000)
SMPP_API_PORT=9000

# ============================================
# INSTALL SCRIPT ONLY (used by install-net2app.sh)
# ============================================
# These are set automatically by the install script.
# Only needed if running the install manually.

# Application port for PM2 (default: 3000)
# APP_PORT=3000

# Domain for Nginx reverse proxy + Let's Encrypt SSL
# DOMAIN=example.com
