#!/bin/bash
# Pre-commit hook: prevent .env files from being committed
# Allows .env.example but blocks .env, .env.local, .env.production, etc.

env_files=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '(^|/)\.env(\.|$)' | grep -v '\.env\.example')

if [ -n "$env_files" ]; then
  echo "ERROR: Attempting to commit environment files containing secrets:"
  echo "$env_files"
  echo ""
  echo "These files may contain credentials and should not be committed."
  echo "Add them to .gitignore instead."
  echo ""
  echo "If you really need to commit one of these files, use:"
  echo "  git commit --no-verify"
  exit 1
fi

exit 0
